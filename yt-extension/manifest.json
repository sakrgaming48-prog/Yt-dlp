{
  "manifest_version": 3,
  "name": "YT-dlp Helper Pro",
  "version": "2.0",
  "description": "Professional YouTube downloader with progress tracking and notifications",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications"
  ],
  "host_permissions": [
    "https://*.youtube.com/*",
    "http://127.0.0.1:8765/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ]
}