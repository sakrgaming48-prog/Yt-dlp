{
  "manifest_version": 3,
  "name": "YT-dlp Helper Pro",
  "version": "2.0",
  "description": "أداة تحميل احترافية فائقة السرعة مع الإشعارات",
  "permissions":[
    "activeTab",
    "downloads",
    "notifications"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches":["*://*.youtube.com/*"],
      "js": ["content.js"]
    }
  ]
}